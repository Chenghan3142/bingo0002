# API Keys Configuration
# Please rename this file to .env and fill in your keys.

# ==========================================
# 1. LLM API Configuration (Choose one or more)
# ==========================================

# OpenAI / DeepSeek / 智谱 等兼容 OpenAI 格式的配置:
OPENAI_API_KEY="your_api_key_here"
# base_url 留空系统默认使用官方接口，如果使用代理或国内大模型请填写
OPENAI_BASE_URL="https://api.openai.com/v1"

# 如果使用 Gemini / Google:
GOOGLE_API_KEY="your_google_api_key_here"

# 如果使用 Anthropic / Claude:
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# ==========================================
# 2. Database & Vector Store Configuration
# ==========================================
# ChromaDB persist directory (Optional, default is ./chroma_db)
CHROMA_PERSIST_DIR="./chroma_db"

# ==========================================
# 3. Market Data Providers (Optional)
# ==========================================
# AlphaVantage API Key (if you use AlphaVantage for global stocks)
ALPHA_VANTAGE_API_KEY=""
# Tushare API Token (For A-Share data)
TUSHARE_TOKEN=""
